<template>
  <div class="app-container">
    <el-row style="display: flex; height: 100vh; overflow: hidden;">
      <!-- 左侧区域 -->
      <el-col style="flex: 0 0 36%; height: 100%; padding-right: 0px; overflow-y: auto;">
        <!-- 操作按钮区 -->
        <action-buttons
          :multiple="multiple"
          :single="single"
          :openNotify="openNotify"
          @add="handleAdd"
          @update="handleUpdate"
          @delete="handleDelete"
          @answer="handleAnswer"
          @accept="handleAccept"
          @refresh="handleRefreshCache"
          @toggleNotify="toggleNotify"
        />

        <!-- 问题表格 -->
        <qa-table
          :loading="loading"
          :data="qaList"
          :total="total"
          :queryParams="queryParams"
          @selection-change="handleSelectionChange"
          @size-change="handleSizeChange"
          @current-change="handleCurrentChange"
          @row-click="handleClick"
          @remind="handleRemind"
        />

        <!-- 问题详情面板 -->
        <question-panel
          :question="selectedQuestion"
          @preview="handlePreview"
          @remove-attachment="handleRemoveAttachment"
        />

        <!-- 讨论区面板 -->
        <forum-panel
          :recordId="selectedQuestion.recordId"
          :replies="replies"
          :replyTotal="replyTotal"
          :queryReply="queryReply"
          :replyLoading="replyLoading"
          @reply="handleSendReply"
          @reply-to="handleReplyTo"
          @reply-delete="handleReplyDel"
          @thumbs-up="handleThumbsUp"
          @reply-size-change="handleReplySizeChange"
          @reply-current-change="handleReplyCurrentChange"
        />
      </el-col>

      <!-- 分割线 -->
      <div style="width: 1px; background-color: #dcdfe6; margin: 0 5px;"></div>

      <!-- 右侧区域 -->
      <el-col style="flex: 1; height: 100%; overflow-y: auto;">
        <!-- 管理员操作区 -->
        <admin-action-buttons
          :adminMultiple="admin_multiple"
          :adminSingle="admin_single"
          :exportLoading="exportLoading"
          :orderByColumn="orderByColumn"
          :isAsc="isAsc"
          :filterSelf="filterSelf"
          :showSearch="showSearch"
          @update-admin="handleUpdateAdmin"
          @delete="handleDelete"
          @export="handleExport"
          @refresh="handleRefreshCache"
          @sort="handleSortCommand"
          @filter="handleReadCommand"
          @search="getSearchList"
        />

        <!-- 管理员表格 -->
        <admin-table
          :loading="admin_loading"
          :data="searchQaList"
          :total="searchTotal"
          :queryParams="searchQueryParams"
          @selection-change="handleAdminSelectionChange"
          @size-change="handleSearchSizeChange"
          @current-change="handleSearchCurrentChange"
          @row-click="handleClick"
          @update-admin="handleUpdateAdmin"
        />
      </el-col>
    </el-row>

    <!-- 各种对话框 -->
    <question-dialog
      :visible="question_open"
      :title="question_title"
      :form="question_form"
      :securityOptions="securityOptions"
      :typeOptions="typeOptions"
      @submit="submitQuestionForm"
      @cancel="cancelQuestion"
      @upload-success="handleUploadQuestionSuccess"
      @remove="handleQuestionRemove"
    />

    <answer-dialog
      :visible="answer_open"
      :title="answer_title"
      :form="answer_form"
      :securityOptions="securityOptions"
      :typeOptions="typeOptions"
      @submit="submitAnswerForm"
      @cancel="cancelAnswer"
      @upload-success="handleUploadAnswerSuccess"
      @remove="handleAnswerRemove"
    />

    <admin-dialog
      :visible="admin_open"
      :title="admin_title"
      :form="admin_form"
      :securityOptions="securityOptions"
      :typeOptions="typeOptions"
      @submit="submitAdminForm"
      @cancel="cancelAdmin"
      @upload-question-success="handleAdminUploadQuestionSuccess"
      @upload-answer-success="handleAdminUploadAnswerSuccess"
      @remove-question="handleAdminQuestionRemove"
      @remove-answer="handleAdminAnswerRemove"
    />

    <export-dialog
      :visible="export_open"
      :form="export_form"
      @submit="submitExportForm"
      @cancel="cancelExport"
    />

    <!-- 图片预览 -->
    <el-image-viewer
      v-if="showImageViewer"
      :on-close="closeImageViewer"
      :url-list="[previewImageUrl]"
    />

    <!-- 转换弹窗 -->
    <conversion-dialog
      :visible="isConverting"
      :progress="convertProgress"
      :message="convertMessage"
    />
  </div>
</template>

<script>
import { useQaSystem } from '@/composables/qa_system'

export default {
  name: "QaAdmin",
  components: {
    ActionButtons: () => import('@/components/ActionButtons'),
    QaTable: () => import('@/components/qaSystem/adminTable'),
    QuestionPanel: () => import('@/components/QuestionPanel'),
    ForumPanel: () => import('@/components/ForumPanel'),
    AdminActionButtons: () => import('@/components/AdminActionButtons'),
    AdminTable: () => import('@/components/AdminTable'),
    QuestionDialog: () => import('@/components/QuestionDialog'),
    AnswerDialog: () => import('@/components/AnswerDialog'),
    AdminDialog: () => import('@/components/AdminDialog'),
    ExportDialog: () => import('@/components/ExportDialog'),
    ConversionDialog: () => import('@/components/ConversionDialog'),
    ElImageViewer: () => import("element-ui/packages/image/src/image-viewer")
  },

  setup() {
    return {
      ...useQaSystem()
    }
  }
};
</script>

<style scoped>
/* 原有的样式保持不变 */
.app-container {
  height: 100vh;
}
