<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sysware.system.mapper.SysUserRoleMapper">

    <resultMap type="SysUserRole" id="SysUserRoleResult">
        <result property="userId" column="user_id"/>
        <result property="roleId" column="role_id"/>
    </resultMap>

    <sql id="selectUserVo">
        select sur.user_id,
               u.user_name,
               u.login_name,
               u.status,
               u.del_flag,
               ss.security_name,
               d.dept_name,
               sur.role_id
        from sys_user_role sur
             left join sys_user u on u.user_id = sur.user_id
             left join sys_security ss on ss.security_id = u.security_id
             left join sys_dept d on u.dept_id = d.dept_id

    </sql>

    <select id="selectMapsPage" resultType="java.util.Map">
        select t.* from (<include refid="selectUserVo"/>) t
        ${ew.customSqlSegment}
    </select>
</mapper>
