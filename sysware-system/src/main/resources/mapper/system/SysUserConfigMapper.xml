<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sysware.system.mapper.SysUserConfigMapper">

    <resultMap type="com.sysware.system.domain.SysUserConfig" id="SysUserConfigResult">
        <result property="userId" column="user_id"/>
        <result property="openNotify" column="open_notify"/>
    </resultMap>


    <sql id="selectSysUserConfigVo">
        select
            t.user_id,
            t.open_notify
        from sys_user_config t
    </sql>

    <select id="selectMapsPage" resultType="java.util.Map">
        select t.* from (<include refid="selectSysUserConfigVo"/>) t

        ${ew.customSqlSegment}

    </select>

    <select id="selectByUserId" resultType="com.sysware.system.domain.SysUserConfig">
        SELECT
            t.user_id,
            t.open_notify
        FROM
            sys_user_config t
        WHERE
            t.user_id = #{userId}
    </select>

    <update id="updateByUserId" parameterType="com.sysware.system.domain.SysUserConfig">
        UPDATE sys_user_config
        SET
            open_notify = #{et.openNotify}
        WHERE
            user_id = #{et.userId}
    </update>
</mapper>
