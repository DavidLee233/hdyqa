<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sysware.system.mapper.SysFormFieldVisibleMapper">

    <resultMap type="com.sysware.system.domain.SysFormFieldVisible" id="SysFormFieldVisibleResult">
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="id" column="id"/>
        <result property="fieldId" column="field_id"/>
        <result property="fieldLabel" column="field_label"/>
        <result property="visibleLabel" column="visible_label"/>
        <result property="visible" column="visible"/>
        <result property="visibleValue" column="visible_value"/>
        <result property="defaultValue" column="default_value"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectVisibleVo">
        select v.id,v.default_value,v.visible,v.visible_label,v.visible_value,v.field_id,DATE_FORMAT(v.create_time,'%y-%m-%d') create_time_str,DATE_FORMAT(v.update_time,'%y-%m-%d') update_time_str,
               v.create_by,v.update_by,v.field_label,v.status
        from sys_form_field_visible v


    </sql>

    <select id="selectMapsPage" resultType="java.util.Map">
        select t.* from (<include refid="selectVisibleVo"/>) t

         ${ew.customSqlSegment}

    </select>

</mapper>
